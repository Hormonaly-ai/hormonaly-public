{
  "name": "@hormonaly/mcp-server",
  "version": "1.0.3",
  "description": "MCP server for the Hormonaly evidence platform — exposes Helix AI, protocol library, compounds, and evidence to Claude and other AI agents",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "hormonaly-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hormonaly",
    "helix",
    "ai",
    "peptides",
    "hormones"
  ],
  "author": "Hormonaly <api@hormonaly.ai>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "hormonaly-mcp-config.json"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hormonaly-ai/hormonaly-public.git",
    "directory": "mcp/hormonaly-mcp-server"
  },
  "homepage": "https://hormonaly.ai/api-docs",
  "bugs": {
    "url": "https://github.com/Hormonaly-ai/hormonaly-public/issues",
    "email": "api@hormonaly.ai"
  }
}
